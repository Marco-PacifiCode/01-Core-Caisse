# ─── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://core:core_dev@localhost:5432/core_caisse?schema=public"

# Rôle PROPRIÉTAIRE (migrations/seed en prod — bypasse la RLS). En prod uniquement, comme core_compta/core_stock.
# DATABASE_URL_OWNER="postgresql://core_caisse_owner:...@localhost:5432/core_caisse?schema=public"

# ─── Auth.js — secret PARTAGÉ entre tous les moteurs ─────────────────────────
# Doit être identique dans chaque moteur (core_auth, core_compta, core_stock, core_caisse…)
# pour décoder la même session JWT. Générer un secret fort en prod : openssl rand -base64 32
AUTH_SECRET="dev-core-PARTAGE-entre-tous-les-moteurs-change-en-prod-0123456789abcdef"

# URL de core_auth (émetteur JWT + résolution tenant par hostname)
CORE_AUTH_URL="http://localhost:3102"

# ─── Clé de service exposée par CE moteur (protège les routes /api/* S2S entrantes) ──
CORE_CAISSE_API_KEY="dev-caisse-service-key-change-en-prod"

# ─── Client SORTANT vers Core-Compta (facture + encaissement) ────────────────
CORE_COMPTA_URL="http://localhost:3101"
CORE_COMPTA_API_KEY="dev-compta-service-key-change-en-prod"

# ─── Client SORTANT vers Core-Stock (décrément à la vente) ───────────────────
CORE_STOCK_URL="http://localhost:3105"
CORE_STOCK_API_KEY="dev-stock-service-key-change-en-prod"

# ─── Mode simulé/mock des clients sortants ───────────────────────────────────
# "1"/"true" → les appels Compta & Stock sont simulés en mémoire (aucun réseau requis).
# Permet de builder / tester la caisse sans que Compta & Stock soient up.
# Laisser vide/absent en prod pour appeler les vrais moteurs.
CORE_CLIENTS_MOCK=""
